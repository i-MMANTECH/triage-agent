# --- Auth (pick ONE path) ---
# Path A (free, no billing): Google AI Studio API key.
# Get one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Path B (production / Vertex AI): Used when GOOGLE_API_KEY is empty.
# Needs an active GCP billing account.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Model:
#   - gemini-2.5-flash → AI Studio FREE tier ✓ (use this while billing is off)
#   - gemini-2.5-pro   → AI Studio PAID / Vertex AI
#   - gemini-3.0-pro   → use once Gemini 3 is enabled in your project
GEMINI_MODEL=gemini-2.5-flash

# --- Dynatrace ---
# Sign up at https://www.dynatrace.com/trial/ for a free 15-day tenant.
DYNATRACE_TENANT_URL=https://YOUR_TENANT.live.dynatrace.com
DYNATRACE_API_TOKEN=dt0c01.PASTE_TOKEN_HERE

# Dynatrace MCP server is launched as a subprocess via stdio.
# Default uses the official npm package; override if you self-host.
DYNATRACE_MCP_COMMAND=npx
DYNATRACE_MCP_ARGS=-y,@dynatrace-oss/dynatrace-mcp-server

# --- Mock mode ---
# When true, the agent uses bundled demo fixtures instead of calling the live
# Dynatrace MCP. Required for the offline demo recording.
TRIAGE_MOCK_MODE=true

# --- Firestore ---
FIRESTORE_COLLECTION_INCIDENTS=triage_incidents
FIRESTORE_COLLECTION_APPROVALS=triage_approvals

# --- Server ---
WEB_ORIGIN=http://localhost:3000
LOG_LEVEL=INFO
